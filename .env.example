# ============================================================
# CoolFTC — Environment Variables (shared template)
# Copy to .env.local and fill in real values. Never commit .env.local.
# ============================================================

# ── Supabase (same instance shared by web + mobile) ─────────
# From Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...

# ── Anthropic (team-owned key — funds trials only) ──────────
# From console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── OpenAI (RAG embeddings — optional) ──────────────────────
# From platform.openai.com. ARIA works without this (no vector retrieval).
OPENAI_API_KEY=sk-...

# ── FTC APIs ────────────────────────────────────────────────
# From ftc-events.firstinspires.org/services/API
FTC_API_KEY=your-ftc-username
FTC_API_SECRET=your-ftc-secret

# ── BYOK Encryption ─────────────────────────────────────────
# Used to encrypt org-owned Anthropic keys in the DB.
# Generate: openssl rand -base64 32
BYOK_ENCRYPTION_KEY=replace-with-32-byte-base64-secret

# ── Mobile-only (Expo public env vars must be EXPO_PUBLIC_*) ─
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...
EXPO_PUBLIC_API_BASE_URL=https://your-app.vercel.app
