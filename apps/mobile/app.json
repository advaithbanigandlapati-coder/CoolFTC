{
  "expo": {
    "name": "CoolFTC",
    "slug": "coolfTC",
    "version": "1.0.0",
    "scheme": "coolfTC",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#07070A",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#07070A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.coolnamepending.coolfTC"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#07070A"
      },
      "package": "com.coolnamepending.coolfTC"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow CoolFTC to access camera for QR scanning and pit photos."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow CoolFTC to record audio for scouting notes."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF5A1F",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}